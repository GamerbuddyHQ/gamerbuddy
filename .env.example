# ─── DATABASE ──────────────────────────────────────────────────────────────
# PostgreSQL connection URL (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/gamerbuddy

# ─── SESSION ───────────────────────────────────────────────────────────────
# Long random string for signing session cookies — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# ─── RAZORPAY ──────────────────────────────────────────────────────────────
# Test keys (start with rzp_test_) — switch to rzp_live_ for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ─── FRONTEND (build-time, must be prefixed VITE_) ─────────────────────────
# If deploying the frontend (Vercel) separately from the API (Railway/Render),
# set this to the full URL of your API server, e.g.:
#   VITE_API_URL=https://gamerbuddy-api.up.railway.app
# Leave empty / omit for same-origin deployment (e.g. everything on Railway).
VITE_API_URL=

# ─── RUNTIME (API server only) ─────────────────────────────────────────────
# Port the Express server listens on (auto-set by Railway/Render — leave empty)
PORT=3001

# ─── DEPLOYMENT NOTES ──────────────────────────────────────────────────────
# FRONTEND (Vercel):
#   Set VITE_API_URL to your backend URL.
#   Set all other VITE_* vars in Vercel → Settings → Environment Variables.
#
# BACKEND (Railway / Render / Fly.io):
#   Set DATABASE_URL, SESSION_SECRET, RAZORPAY_KEY_ID, RAZORPAY_KEY_SECRET.
#   Set NODE_ENV=production.
#   PORT is provided automatically by the platform.
#
# WEBSOCKETS (Socket.io):
#   Socket.io requires a persistent server — it is NOT compatible with
#   Vercel serverless functions. The backend MUST run on Railway/Render/Fly.io.
